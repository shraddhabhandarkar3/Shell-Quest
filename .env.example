# Box integration (player state, AI hints, challenge tasks, leaderboard)
# Developer Token from your Box Custom App in the Developer Console.
# NOTE: developer tokens expire after 60 minutes — regenerate one before a
# demo/session and paste the fresh value here.
BOX_DEVELOPER_TOKEN=
# Client ID / Secret from the SAME Box app the token came from.
BOX_CLIENT_ID=
BOX_CLIENT_SECRET=
# ID of the Box folder where player state is stored.
# (create it with: python scripts/setup_box.py)
BOX_STATE_FOLDER_ID=

# Apify integration (theme content scraping + shell challenge sourcing)
# API token from https://console.apify.com/account/integrations
APIFY_API_TOKEN=
