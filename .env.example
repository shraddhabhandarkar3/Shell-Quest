# Box integration (player state persistence)
# Path to the Box JWT app config JSON downloaded from the Box developer console
BOX_CONFIG_PATH=
# ID of the Box folder where player state JSON files are stored
# (create it with: python scripts/setup_box.py)
BOX_STATE_FOLDER_ID=

# Apify integration (content scraping, hints, GitHub profiles)
# API token from https://console.apify.com/account/integrations
APIFY_API_TOKEN=
