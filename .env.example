# Box integration (player state, AI hints, challenge tasks, leaderboard)
# Client ID / Secret from your Box Custom App.
BOX_CLIENT_ID=
BOX_CLIENT_SECRET=
#
# AUTH — pick ONE (auto-refreshing CCG is strongly preferred for demos):
#  • CCG as user (best): set BOX_USER_ID to your Box user id. Auto-refreshes
#    forever, files live in your personal Box. Requires the app to have
#    "Generate user access tokens" enabled and be authorized in the Admin Console.
BOX_USER_ID=
#  • CCG as enterprise (service account): set BOX_ENTERPRISE_ID instead.
BOX_ENTERPRISE_ID=
#  • Developer Token (fallback only): expires after 60 minutes.
BOX_DEVELOPER_TOKEN=
#
# ID of the Box folder where player state is stored.
# (create it with: python scripts/setup_box.py)
BOX_STATE_FOLDER_ID=

# Apify integration (theme content scraping + shell challenge sourcing)
# API token from https://console.apify.com/account/integrations
APIFY_API_TOKEN=
